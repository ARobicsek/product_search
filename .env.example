# Copy to `.env` and fill in. `.env` is gitignored.
# In GitHub Actions, set these as repository secrets with the same names.
# In Vercel, set these as environment variables for the web app.

# --- LLM providers (set the ones you want to use; benchmark picks among them) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GLM_API_KEY=

# --- eBay Browse API (Phase 2+) ---
# Register an app at https://developer.ebay.com/. Use the production credentials.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# --- GitHub (used by web UI to dispatch on-demand worker runs) ---
# Fine-grained PAT with `actions: write` on this repo only.
GITHUB_DISPATCH_TOKEN=
GITHUB_REPO=ARobicsek/product_search

# --- Web Push (Phase 11; iOS PWA notifications) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ari.robicsek@gmail.com

# --- Vercel KV (for push subscription storage; auto-injected by Vercel) ---
# Set in the Vercel project, not in local .env. Listed here for reference.
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Optional: secondary notification channel ---
SLACK_WEBHOOK_URL=

# --- Web ↔ worker shared secret ---
# Used by the web app's /api/dispatch and /api/push/notify to authenticate.
# Generate with: openssl rand -hex 32
WEB_SHARED_SECRET=
