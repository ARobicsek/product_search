# Copy to `.env` and fill in. `.env` is gitignored.
# In GitHub Actions, set these as repository secrets with the same names.
# In Vercel, set these as environment variables for the web app.

# --- LLM providers (set the ones you want to use; benchmark picks among them) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GLM_API_KEY=

# --- Synthesizer model selection (Phase 5+) ---
# Defaults below were picked by the Phase 5 benchmark. Override per-run.
LLM_SYNTH_PROVIDER=glm
LLM_SYNTH_MODEL=glm-4.5-flash

# --- Onboarding model selection (Phase 14+) ---
# Phase 14 swapped from glm-5.1 → claude-haiku-4-5 with Anthropic's native
# web_search server-tool + ephemeral prompt caching on the system prompt.
# Cuts repeat-turn input cost ~90% via cache reads. Supersedes ADR-014/-015.
LLM_ONBOARD_PROVIDER=anthropic
LLM_ONBOARD_MODEL=claude-haiku-4-5

# --- eBay Browse API (Phase 2+) ---
# Register an app at https://developer.ebay.com/. Use the production credentials.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# --- AlterLab (Phase 12d, ADR-029 follow-up) ---
# VESTIGIAL post-ADR-139 (Phase 36 retired the self-scraping tier; the
# universal_ai_search adapter no longer exists). Kept only so existing
# environments don't error on an unset var; candidate to remove. Unused at runtime.
# Optional. When set, the universal_ai_search adapter routes vendor page
# fetches through AlterLab with render_js=true + asp=true. Gets us past
# Cloudflare/Akamai/Datadome and full-React storefronts that the cheap
# curl_cffi tier can't render. When
# UNSET, the adapter falls back to curl_cffi/httpx (no JS rendering).
ALTERLAB_API_KEY=

# --- Scrappey (ADR-103; Cloudflare-walled vendor bypass) ---
# VESTIGIAL post-ADR-139 (Phase 36 retired the self-scraping tier + vendor_quirks
# registry). Unused at runtime; candidate to remove. Amazon recall now uses the
# structured DataForSEO API above, NOT Scrappey (ADR-141 records why not).
# Optional. When set AND a vendor has `use_scrappey: true` in vendor_quirks.yaml,
# the universal_ai_search adapter routes fetches through Scrappey's browser-render
# API with a US residential proxy, bypassing Cloudflare Turnstile/WAF. PAYG
# (EUR 1/1K browser requests, no subscription). Only CF-walled vendors use this;
# all others stay on AlterLab/curl_cffi.
SCRAPPEY_API_KEY=

# --- Serper.dev (Phase 30; shopping/search recall primitive — ADR-130) ---
# PAYG Google Search/Shopping API. The Phase 30 spike uses this to fetch
# structured listings (title/price/seller/link) as a recall primitive, instead
# of self-scraping adversarial vendor pages. Free tier: 2,500 credits (~1,250
# shopping calls at 2 credits each); then ~$0.30-$1.00/1k. Shopping endpoint:
# POST https://google.serper.dev/shopping  header: X-API-KEY.
# Prod homes: GitHub Actions repo secret (worker runs) + Vercel env (if the
# onboarder/web ever calls it). NEVER commit the real key.
SERPER_API_KEY=

# --- Local LLM filter backend (Phase 42; ADR-147) — LOCAL/DEV OPT-IN ---
# By default the ai_filter runs on Anthropic Haiku (AI_FILTER_BACKEND unset).
# Set AI_FILTER_BACKEND=local to route it to a home llama-swap box (OpenAI-
# compatible) at ~zero cost, behind a polite shared-box coordinator + a
# local->local fallback chain (schema-constrained decoding keeps the JSON valid).
# This is a LOCAL/dev opt-in only — GitHub-Actions->home-box reachability is a
# separate, still-deferred decision, so prod leaves AI_FILTER_BACKEND unset and
# stays on Haiku. The box ignores the key (any non-empty string works).
# AI_FILTER_BACKEND=local
# LOCAL_LLM_BASE=http://100.68.68.101:8080/v1
# LOCAL_LLM_KEY=dummy
# LOCAL_LLM_MODEL=qwen-coder
# LOCAL_LLM_FALLBACK_MODEL=qwen3.6-27b-mtp   # secondary LOCAL model if the primary fails a batch
# LOCAL_LLM_IDLE_WAIT_SECS=300   # wait this long for a different in-use model to idle
# LOCAL_LLM_MAX_WAIT_SECS=600    # bound the wait, then proceed/fallback (never hangs)
# LOCAL_LLM_POLL_SECS=15
# Haiku reachability fallback: ON in dev (a busy/unreachable box falls back to
# Haiku so a dev run never hangs). In PROD set this to 0 for cost ~0 / NO Haiku:
# the chain stays local-only and a total local failure fires a push notification
# (WEB_URL + PUSH_NOTIFY_SECRET) so you can investigate, instead of paying Haiku.
# LOCAL_LLM_ALLOW_HAIKU_FALLBACK=1

# --- DataForSEO Amazon Products (Phase 38; Amazon recall — ADR-141) ---
# Structured PAYG Amazon "Merchant > Amazon Products" API. run_v2's amazon
# adapter (adapters/amazon.py) maps DataForSEO's structured JSON (asin/title/
# price/url/rating) to listings — NO HTML scraping. HTTP Basic auth with an
# account login + password (NOT an API key). Amazon recall is OFF by default
# (sources.amazon.enabled, set per-product by the onboarder), so these are only
# needed once a profile enables Amazon. Prepaid PAYG (~$0.001/search Standard
# queue), no subscription, balance never expires. Register at
# https://dataforseo.com/. Prod homes: GitHub Actions repo secrets (worker runs;
# mapped into both search workflows) + local .env. NEVER commit the real values.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- GitHub (used by web UI to dispatch on-demand worker runs) ---
# Fine-grained PAT with `actions: write` on this repo only.
GITHUB_DISPATCH_TOKEN=
# Fine-grained PAT with `contents: write` on this repo only. Used by the
# /api/onboard/save endpoint to commit a new products/<slug>/profile.yaml.
# If unset, the onboarding endpoint falls back to GITHUB_DISPATCH_TOKEN, which
# in that case must have BOTH `actions: write` AND `contents: write`.
GITHUB_CONTENTS_TOKEN=
GITHUB_REPO=ARobicsek/product_search

# --- Web Push (Phase 11; iOS PWA notifications) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ari.robicsek@gmail.com

# --- Worker -> web notify bridge (REQUIRED for alert pushes to ever send) ---
# notify.py POSTs fired alerts to {WEB_URL}/api/push/notify with a Bearer
# PUSH_NOTIFY_SECRET. If EITHER is unset the worker silently skips the POST
# (the alert still fires + disarms in alerts_state.json, so it looks "fired"
# but nothing is delivered). These MUST also be set as GitHub Actions repo
# secrets (both search workflows reference them) and PUSH_NOTIFY_SECRET must
# equal the same-named value in the Vercel project.
WEB_URL=
PUSH_NOTIFY_SECRET=

# --- Vercel KV (for push subscription storage; auto-injected by Vercel) ---
# Set in the Vercel project, not in local .env. Listed here for reference.
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Optional: secondary notification channel ---
SLACK_WEBHOOK_URL=

# --- Web ↔ worker shared secret ---
# Used by the web app's /api/dispatch and /api/push/notify to authenticate.
# Generate with: openssl rand -hex 32
WEB_SHARED_SECRET=
# Browser-exposed copy for /api/dispatch (the "Run now" button reads this).
# In Vercel, set this to the same value as WEB_SHARED_SECRET unless and until
# /api/push/notify gets its own distinct secret in Phase 11.
NEXT_PUBLIC_WEB_SHARED_SECRET=

# --- External scheduler trigger (Phase 20; ADR-052) ---
# Server-only shared secret guarding /api/cron/tick. cron-job.org (every 15
# min) POSTs that route with an `x-cron-secret: <this value>` header; the route
# then forwards a workflow_dispatch to search-scheduled.yml using
# GITHUB_DISPATCH_TOKEN. Low-value secret (a leak only lets someone force a
# scheduler tick) — keep it server-only, NO NEXT_PUBLIC_ twin. MUST be set in
# Vercel **Production** env (then redeploy). Generate with: openssl rand -hex 32
CRON_TRIGGER_SECRET=
